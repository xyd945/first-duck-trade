# Copy this file to .env and fill in your values
# .env is gitignored — your secrets stay local

# LLM provider selection — "deepseek" (default) or "anthropic".
# The wrapper falls back to the OTHER provider automatically on transport
# errors, so setting just one key works but setting both gives you a hot
# spare for free.
LLM_PROVIDER=deepseek

# DeepSeek API key (default provider). Get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Anthropic API key (fallback provider, also used if LLM_PROVIDER=anthropic).
# Optional if you only want to run on DeepSeek — but keeping both means a
# DeepSeek outage doesn't halt the strategy factory.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Orchestrator mode: "dry-run" (default) or "live"
ORCHESTRATOR_MODE=dry-run

# Telegram notifications (optional — leave empty to disable)
# Create a bot via @BotFather, get your chat_id from @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
