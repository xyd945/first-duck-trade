{
    "spec_type": "freqai",
    "name": "FreqaiLgbmBaseline",
    "thesis": "A gradient-boosted regressor over momentum, volatility, volume and macro-context features can predict next-day returns well enough to beat threshold-gated long entries against HODL.",
    "target_regime": "all",
    "features": [
        "rsi", "ema_dist", "natr", "adx", "bb_width", "roc", "volume_z",
        "pct_change", "hl_range", "time_cycle",
        "funding", "oi_change", "eth_btc", "alt_strength",
        "macro_fgi", "macro_vix"
    ],
    "target": {"type": "future_return", "horizon_candles": 24},
    "model": {
        "family": "LightGBMRegressor",
        "params": {
            "n_estimators": 400,
            "learning_rate": 0.05
        }
    },
    "thresholds": {"entry": 0.005, "exit": 0.0},
    "freqai": {
        "train_period_days": 60,
        "backtest_period_days": 7,
        "include_shifted_candles": 2,
        "indicator_periods_candles": [14, 50],
        "test_size": 0.25
    },
    "risk": {
        "stoploss": -0.06,
        "minimal_roi": {"0": 0.15, "60": 0.08, "120": 0.04, "240": 0.02}
    },
    "generation_id": "freqai-spec-baseline"
}
