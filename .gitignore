# Claude Code assistant memory (local-only context, not for sharing)
AGENTS.md

# Environment variables (API keys)
.env

# User specific configurations (API keys, etc.)
user_data/config.json
# Match every file inside user_data/configs/ but NOT subdirectories — keeps
# the rendering templates trackable. (A directory-level ignore here would
# block git from descending, so `!*.template` couldn't re-include them.)
user_data/configs/*.json
user_data/configs/.*
# The FreqAI base config is deliberately secrets-free (dry-run, empty
# exchange keys, no api_server) and is read verbatim — no env rendering —
# so unlike the instance configs it is committed, not templated (issue #47).
!user_data/configs/config-freqai-base.json

# Freqtrade download data
user_data/data/

# Backtest results
user_data/backtest_results/

# Hyperopt results + runtime lock file
user_data/hyperopt_results/
user_data/hyperopt.lock

# Plot dataframe results
user_data/plot/

# Exchange logs
user_data/logs/

# Python virtual env
.venv/

# Python artifacts
__pycache__/
*.py[cod]
*$py.class

# SQLite databases (per-instance) and WAL/SHM files
user_data/tradesv3*.sqlite
user_data/tradesv3*.sqlite-shm
user_data/tradesv3*.sqlite-wal

# LLM-generated strategy candidates (runtime artifacts)
# Keep the base classes and .gitkeep so the dir + import path survive
user_data/strategies/candidates/*
!user_data/strategies/candidates/.gitkeep
!user_data/strategies/candidates/base_generated.py
!user_data/strategies/candidates/base_freqai.py

# FreqAI runtime artifacts (issue #47): trained models are purged after
# evaluation anyway; rendered per-candidate configs are regenerated from
# their specs at registration time
user_data/models/
user_data/configs/freqai/

# Jupyter Notebooks
.ipynb_checkpoints
user_data/notebooks/.ipynb_checkpoints

# OS specific
.DS_Store
Thumbs.db

# IDE specific
.vscode/
.idea/

# Docker
docker-compose.override.yml
