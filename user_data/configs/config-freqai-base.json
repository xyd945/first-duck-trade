{
    "$schema": "https://schema.freqtrade.io/schema.json",
    "_comment": [
        "Base config for FreqAI backtests (issue #47). Dry-run only, no",
        "secrets — safe to commit and to copy per-candidate. The factory",
        "renders one config per FreqAI candidate from this base via",
        "freqai_spec.render_freqai_config(): the freqai block below gets",
        "the spec's training window / horizon / model params and a unique",
        "identifier so model artifacts never collide between candidates."
    ],
    "max_open_trades": 3,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.99,
    "fiat_display_currency": "USD",
    "dry_run": true,
    "dry_run_wallet": 1000,
    "cancel_open_orders_on_exit": false,
    "trading_mode": "futures",
    "margin_mode": "isolated",
    "unfilledtimeout": {
        "entry": 10,
        "exit": 10,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "okx",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT:USDT",
            "ETH/USDT:USDT",
            "SOL/USDT:USDT"
        ],
        "pair_blacklist": []
    },
    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],
    "freqai": {
        "enabled": true,
        "identifier": "freqai-baseline-lgbm",
        "purge_old_models": 2,
        "train_period_days": 60,
        "backtest_period_days": 7,
        "fit_live_predictions_candles": 300,
        "feature_parameters": {
            "include_timeframes": ["1h"],
            "include_corr_pairlist": [],
            "label_period_candles": 24,
            "include_shifted_candles": 2,
            "indicator_periods_candles": [14, 50],
            "principal_component_analysis": false,
            "use_SVM_to_remove_outliers": false
        },
        "data_split_parameters": {
            "test_size": 0.25,
            "shuffle": false
        },
        "model_training_parameters": {
            "n_estimators": 400,
            "learning_rate": 0.05,
            "n_jobs": 4
        }
    },
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": ""
    },
    "bot_name": "freqtrade-freqai-backtest",
    "initial_state": "running",
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    }
}
