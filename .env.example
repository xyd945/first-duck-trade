# Copy this file to .env and fill in your values.
# .env is gitignored — your secrets stay local.
#
# At container startup, render_config.py materializes the freqtrade
# configs into /tmp inside each container (chmod 0600, not host-mounted)
# from the values below. Missing or empty values fail the render
# immediately with a clear error.
#
# After upgrading past the /tmp-render PR: any leftover
# user_data/configs/config-*.json files on your host disk are now dead
# weight — safe (and recommended) to delete. Only the *.json.template
# siblings are read.

# LLM provider selection — "deepseek" (default) or "anthropic".
# The wrapper falls back to the OTHER provider automatically on transport
# errors, so setting just one key works but setting both gives you a hot
# spare for free.
LLM_PROVIDER=deepseek

# DeepSeek API key (default provider). Get one at https://platform.deepseek.com
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Anthropic API key (fallback provider, also used if LLM_PROVIDER=anthropic).
# Optional if you only want to run on DeepSeek — but keeping both means a
# DeepSeek outage doesn't halt the strategy factory.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Per-request HTTP timeout for LLM calls, in seconds. Default 300.
# A DeepSeek V4 Pro reasoning-model generation typically takes 30-180s;
# 300s leaves headroom while still detecting silent stream stalls (trials
# #4 and #6 each lost 2+ hours to a hung connection). Lower this if your
# operator wants tighter fail-fast.
# LLM_REQUEST_TIMEOUT_SECONDS=300

# Strict pipeline-gate aggregation. Default: true.
# When true (production), every promotion gate must produce an explicit
# pass — a "skip" verdict (missing reference data, n/a regime, degenerate
# 0%-vs-0% comparison) counts as fail. When false, the legacy lenient
# aggregation is used: skips count as pass, so a candidate can promote
# with thin or missing validation data. Flip to false ONLY for research
# / exploration phases where you don't have full reference data wired up.
# STRICT_PROMOTION_GATES=true

# Deployment-lifecycle reconciler (see docs/deployment-lifecycle.md).
# In Phase 2, the reconciler runs every 5 minutes in OBSERVE-ONLY mode —
# it computes the desired-vs-running diff and persists each tick to
# deployment_drift_log, but does not start or stop any container. The
# RECONCILER_ACTING flag is plumbed through end-to-end but ignored
# until Phase 3 ships. Operators can read past observations with
# strategy_registry.get_recent_drift_logs(n).
# RECONCILER_ACTING=false
# MAX_DEPLOYED=3
# DEPLOYMENT_CORR_THRESHOLD=0.7

# Orchestrator mode: "dry-run" (default) or "live"
ORCHESTRATOR_MODE=dry-run

# -----------------------------------------------------------------------------
# OKX API credentials — rendered into both freqtrade configs at container
# startup by user_data/scripts/render_config.py. Demo / paper-trading
# credentials (sandboxMode=true is hardcoded in the templates); these never
# touch real funds. Generate them at https://www.okx.com/trade-demo and
# copy here. The freqtrade containers will refuse to start if any are unset.
# -----------------------------------------------------------------------------
OKX_API_KEY=
OKX_API_SECRET=
OKX_API_PASSPHRASE=

# -----------------------------------------------------------------------------
# Freqtrade REST API credentials — used internally between the orchestrator
# and ft-momentum / ft-sweep containers over the docker network. Any random
# strings work; pick something unguessable. JWT secrets sign session tokens
# and should be 32+ random chars. The orchestrator and each freqtrade
# container must agree on the API password for that instance.
# -----------------------------------------------------------------------------
FT_MOMENTUM_API_PASSWORD=
FT_SWEEP_API_PASSWORD=
FT_MOMENTUM_JWT_SECRET=
FT_SWEEP_JWT_SECRET=

# Telegram notifications (optional — leave empty to disable)
# Create a bot via @BotFather, get your chat_id from @userinfobot
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=
